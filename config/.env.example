# 🔐 SYNDRA AGENT - Arquivo de Configuração
# ⚠️ NÃO COMMITAR ESTE ARQUIVO! Use .gitignore
# ⚠️ CRIAR .env LOCAL COM SEUS VALORES

# ═══════════════════════════════════════════════════════════════════════════
# 🔒 SEGURANÇA - CRÍTICO
# ═══════════════════════════════════════════════════════════════════════════

# Gerar chave: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=gere-uma-chave-aleatoria-forte-aqui

# Gerar token: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_TOKEN=gere-um-token-para-validacao-webhook

# ═══════════════════════════════════════════════════════════════════════════
# 🏢 CONDOMÍNIO - CONFIGURÁVEL POR CLIENTE (Sem Hardcoding!)
# ═══════════════════════════════════════════════════════════════════════════

# Nome do condomínio - CUSTOMIZÁVEL PARA CADA CLIENTE
CONDO_NAME="Condomínio SaaS"

# Dados do condomínio
CONDO_CNPJ="12.345.678/0001-99"
CONDO_ADDRESS="Rua Exemplo, 123 - São Paulo, SP"

# ID para multi-tenancy
CONDO_ID="default"

# ═══════════════════════════════════════════════════════════════════════════
# 🤖 IA & LLM
# ═══════════════════════════════════════════════════════════════════════════

# Nome do agente
AGENT_NAME="Syndra"
AGENT_ROLE="Assistente Virtual do Condomínio"

# LLM Configuration
LLM_MODEL="gpt-4-turbo-preview"
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# OpenRouter (Recomendado - Suporta múltiplos modelos)
USE_OPENROUTER=true
OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui
OPENROUTER_MODEL=openai/gpt-4-turbo-preview

# Alternativa: OpenAI Direto
OPENAI_API_KEY=sk-sua-chave-openai

# Embeddings
EMBEDDINGS_MODEL=text-embedding-3-small
VECTOR_DIMENSION=1536
MAX_CONTEXT_CHUNKS=5

# ═══════════════════════════════════════════════════════════════════════════
# 💬 WHATSAPP - EVOLUTION API
# ═══════════════════════════════════════════════════════════════════════════

# URL do servidor Evolution API
EVOLUTION_API_URL=http://localhost:8080

# API Key do Evolution
EVOLUTION_API_KEY=sua-chave-evolution-api

# Nome da instância WhatsApp
EVOLUTION_INSTANCE=syndra

# Reconectar automaticamente
EVOLUTION_RECONNECT=true

# ═══════════════════════════════════════════════════════════════════════════
# 🗄️ SUPABASE - Banco de Dados
# ═══════════════════════════════════════════════════════════════════════════

# URL do projeto (encontre em Settings > API)
SUPABASE_URL=https://seu-projeto.supabase.co

# Service Role Key (Backend only - Nunca exponha!)
# Encontre em: Settings > API > Service Role
SUPABASE_SERVICE_KEY=seu-service-role-key-aqui

# Anonymous Key (Seguro usar no frontend)
# Encontre em: Settings > API > anon key
SUPABASE_ANON_KEY=sua-anon-key-aqui

# Access Token (Optional)
SUPABASE_ACCESS_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# 💾 REDIS - Cache & Sessões
# ═══════════════════════════════════════════════════════════════════════════

# URL de conexão Redis
REDIS_URL=redis://localhost:6379

# Senha (se configurado)
REDIS_PASSWORD=

# Database (0-15)
REDIS_DB=0

# ═════════════════════════════════════════════════════════════════════════════
# 🌐 APLICAÇÃO
# ═════════════════════════════════════════════════════════════════════════════

# Ambiente (development, staging, production)
APP_ENV=development

# Debug (SEMPRE false em produção!)
DEBUG=false

# Host e porta
APP_HOST=0.0.0.0
APP_PORT=8000

# ═════════════════════════════════════════════════════════════════════════════
# 📋 LOGGING & MONITORING
# ═════════════════════════════════════════════════════════════════════════════

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Formato de log (json ou plain)
LOG_FORMAT=json

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENABLED=false

# ═════════════════════════════════════════════════════════════════════════════
# 🔒 CORS & Rate Limiting
# ═════════════════════════════════════════════════════════════════════════════

# CORS - Em produção, restringir a domínios específicos
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ═════════════════════════════════════════════════════════════════════════════
# ✨ FEATURE FLAGS
# ═════════════════════════════════════════════════════════════════════════════

ENABLE_RAG=true
ENABLE_MEMORY=true
ENABLE_TOOLS=true
ENABLE_AUDIT_LOG=true

# ═════════════════════════════════════════════════════════════════════════════
# 📝 INSTRUÇÕES DE PREENCHIMENTO
# ═════════════════════════════════════════════════════════════════════════════

# 1. SUPABASE:
#    - Criar conta em https://supabase.com
#    - Criar novo projeto
#    - Copiar URL e keys de Settings > API
#
# 2. OPENROUTER (Recomendado):
#    - Registrar em https://openrouter.ai
#    - Gerar API key em https://openrouter.ai/keys
#    - Adicionar créditos
#
# 3. EVOLUTION API:
#    - Instalar em servidor separado
#    - Gerar API key no painel
#
# 4. REDIS:
#    - Desenvolvimento: localhost
#    - Produção: Upstash ou gerenciado
#
# 5. SEGURANÇA:
#    - SECRET_KEY: Gerar aleatório e forte
#    - WEBHOOK_TOKEN: Gerar para validação
#    - Nunca commitar este arquivo!

